# MySQL connection string
DATABASE_URL=mysql://user:password@localhost:3306/battleship

# Set to true to require SSL for database connections
DATABASE_SSL=false

# Secret for signing JWT tokens (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-string

# Comma-separated list of allowed origins for CORS (leave empty for permissive in dev)
# ALLOWED_ORIGINS=https://yourdomain.com

PORT=3000
